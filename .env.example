# ==== 환경 변수 샘플 (복사해서 .env 로 사용) ====

# 앱 환경 (dev | prod)
APP_ENV=dev

# DB 접속 문자열 (기본: SQLite, Postgres 전환 시 교체)
DATABASE_URL=sqlite:///db/app.db

# 파일 저장 루트
STORAGE_DIR=./storage

# 업로드 최대 크기(MB)
MAX_UPLOAD_MB=200

# 인증 모드 (none | basic)
AUTH_MODE=none

# 학습 기본 테스트 비율
DEFAULT_TEST_SIZE=0.2

# 학습 재현성 랜덤 시드
RANDOM_SEED=42

# 로깅 레벨
LOG_LEVEL=INFO
